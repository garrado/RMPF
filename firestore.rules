rules_version = '2';
// INSTRUÇÕES: Copie este arquivo no Firebase Console → Firestore → Rules
// Projeto: visam-3a30b (compartilhado com garrado/VISA)
service cloud.firestore {
  match /databases/{database}/documents {

    // Coleção de usuários — compartilhada com garrado/VISA
    match /usuarios/{email} {
      // Qualquer usuário autenticado pode ler
      allow read: if request.auth != null;

      // Escrita: o próprio usuário OU um Administrador
      allow write: if request.auth != null &&
        (request.auth.token.email == email ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador');

      // Update pelo próprio usuário: apenas campos de perfil público e dados de acesso
      allow update: if request.auth != null &&
        request.auth.token.email == email &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['photoURL', 'ultimoAcesso', 'appVersionLast', 'dispositivos']);
    }

    // Manuais: fiscal cria/lê os seus; Administrativo/Administrador lê todos; Administrador/Administrativo importa para qualquer fiscal
    match /manuais/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.fiscal_email == request.auth.token.email ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador' ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrativo'
      );
      allow create: if request.auth != null && (
        request.resource.data.fiscal_email == request.auth.token.email ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador' ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrativo'
      );
      allow update: if request.auth != null && (
        (resource.data.fiscal_email == request.auth.token.email &&
          resource.data.status != 'fechado' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['anexo_url', 'anexo_nome', 'anexo_path', 'anexo_bytes', 'updated_at'])) ||
        (resource.data.fiscal_email == request.auth.token.email &&
          (resource.data.status == 'rascunho' ||
           (resource.data.origem == 'visa_csv' && resource.data.status != 'aceito' && resource.data.status != 'fechado'))) ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador' ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrativo'
      );
      allow delete: if request.auth != null && (
        (resource.data.fiscal_email == request.auth.token.email &&
          (resource.data.status == 'rascunho' || resource.data.status == 'enviado')) ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador'
      );
    }

    // Ocorrências: fiscal cria/lê as suas; Administrativo/Administrador analisa todas
    match /ocorrencias/{docId} {
      allow read: if request.auth != null && (
        resource.data.fiscal_email == request.auth.token.email ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador' ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrativo'
      );
      allow create: if request.auth != null
        && request.resource.data.fiscal_email == request.auth.token.email;
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador';
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador';
    }

    // CVS overrides: somente Administrador escreve; todos os autenticados leem
    match /cvs_override/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador';
    }

    // CNAE Complexidade: qualquer autenticado lê; somente Administrador escreve (seed)
    match /cnae_complexidade/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador';
    }

    // Lock de importação VISA: qualquer autenticado lê, cria, atualiza e apaga.
    // A exclusividade é garantida por transação no cliente — a rule apenas abre o acesso.
    match /visa_import_locks/{docId} {
      allow read, write: if request.auth != null;
    }

    // Lock de importação SIM: qualquer autenticado lê, cria, atualiza e apaga.
    // A exclusividade é garantida por transação no cliente — a rule apenas abre o acesso.
    match /sim_import_locks/{docId} {
      allow read, write: if request.auth != null;
    }

    // Fechamentos: Administrativo/Administrador escreve; fiscal lê o seu próprio
    match /fechamentos/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.fiscal_email == request.auth.token.email ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador' ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrativo'
      );
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador' ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrativo'
      );
    }

    // Configuração do app (ex.: token GitHub): qualquer autenticado lê; somente Administrador escreve
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.grupo == 'Administrador';
    }

    // Qualquer outra coleção: bloqueado por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
